MONGODB_URI=MongoDB connection link
FRONTEND_URL=frontend url
ACCESS_TOKEN_SECRET=Local authentication secret token  for accessToken (to be generated by the user)
REFRESH_TOKEN_SECRET=Local authenticatino secret token for refreshToken (to be generated by the user)
GOOGLE_CLIENT_ID=From Google cloud console
GOOGLE_CLIENT_SECRET=From Google cloud console
GOOGLE_CALLBACK_URL= Google callback url
DAUTH_CLIENT_ID=From DAuth clients
DAUTH_CLIENT_SECRET= From DAuth clients
DAUTH_CALLBACK_URL=DAuth callback url
PRODUCTION=true
SUPABASE_ENDPOINT=supabase endpoint url
SUPABASE_REGION= cloud storage region
SUPABASE_BUCKET_NAME= bucket name
SUPABASE_APPLICATION_KEY_ID= application key id from SUPABASE
SUPABASE_APPLICATION_KEY= application key from SUPABASE
EMAIL_USER= From Email for notifying strikes to the user ( to be implemeted )
EMAIL_PASSWORD=Email password ( to be implemented )